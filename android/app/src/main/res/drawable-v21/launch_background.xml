<?xml version="1.0" encoding="utf-8"?>
<!-- API 21+ launch window (the variant real devices actually use). Same maroon
     brand background + centred logo as the base drawable, in both light and dark
     system themes, matching the Flutter splash so there is no white flash. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/splash_bg" />

    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/splash_logo" />
    </item>
</layer-list>
