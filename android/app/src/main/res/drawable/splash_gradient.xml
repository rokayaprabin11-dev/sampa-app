<?xml version="1.0" encoding="utf-8"?>
<!-- The app header gradient (AppTheme.navGradient) for the pre-Android-12 native
     launch window: temple-red at the top, terracotta at the bottom. Android
     shape gradients spread the three colours evenly (mid at 50%, vs the app's
     60%) and cannot take a stops array, so this is a close match, not exact.
     Android 12+ cannot use a gradient at all (its system splash is a single
     colour) — it uses the top maroon instead. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#5C1A0A"
        android:centerColor="#A83210"
        android:endColor="#C8501A" />
</shape>
