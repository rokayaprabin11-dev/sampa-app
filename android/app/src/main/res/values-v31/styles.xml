<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31) draws its own system splash and ignores
         windowBackground for it, so the maroon has to be set through the
         dedicated splash-screen attributes here — otherwise 12+ devices flash
         the system default (often white) before the window background applies.
         Background + icon match the Flutter splash for one continuous screen. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
